  "keyFeatures": [
    "Client Management with DNI/RUC validation",
    "Legal Case (Casos) tracking and management",
    "Conciliation Process (Expedientes) with document handling",
    "Document upload and management system",
    "Calendar and activity scheduling with FullCalendar integration",
    "Role-based access control (Admin, Encargado, Asistente, Abogado)",
    "Search functionality with Laravel Scout",
    "Dashboard with ChartJS analytics"
  ],
  "publicApiSurface": [
    "ClienteController: index, create, store, show, edit, update, destroy, search",
    "CasosController: index, create, store, show, edit, update, destroy, assignProceso, removeProceso",
    "ExpedienteController: index, create, store, show, edit, update, destroy, assignSubmateria, removeSubmateria",
    "ActividadController: index, create, store, edit, update, destroy",
    "CalendarController: index",
    "User Management: RoleController, PermissionController, UserController",
    "ConciliadorController: index, create, store",
    "SubmateriaController: index, create, edit, update, destroy",
    "Document Controllers: ExpedienteDocumentosController, CasoDocumentoController"
  ]
